#!/usr/bin/env bash

####################################################################
#                                                                  #
# File: ~/.bashrc.init                                             #
#                                                                  #
# Usage:                                                           #
#                                                                  #
# Add the following line into ~/.bashrc to load it                 #
#                                                                  #
#   [[ -f ~/.bashrc.init ]] && source ~/.bashrc.init               #
#                                                                  #
####################################################################

[[ -f ~/.bashrc.env ]] && source ~/.bashrc.env

for file in "$HOME"/.bashrc.includes/*; do
    source "$file"
done

[[ -f ~/.bashrc.local ]] && source ~/.bashrc.local